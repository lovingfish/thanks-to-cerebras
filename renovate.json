{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)",
    ":prHourlyLimit2"
  ],
  "prConcurrentLimit": 5,
  "timezone": "Asia/Shanghai",
  "schedule": [
    "before 9am on the first day of the month"
  ],
  "minimumReleaseAge": "3 days",
  "labels": [
    "dependencies"
  ],
  "commitMessageTopic": "{{depName}}",
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "before 9am on the first day of the month"
    ]
  },
  "packageRules": [
    {
      "description": "Group Deno and JSR dependency updates",
      "matchManagers": [
        "deno"
      ],
      "groupName": "deno dependencies",
      "addLabels": [
        "area: dependencies"
      ]
    },
    {
      "description": "Group GitHub Actions updates",
      "matchManagers": [
        "github-actions"
      ],
      "groupName": "github actions",
      "addLabels": [
        "area: ci"
      ]
    },
    {
      "description": "Group Docker image updates",
      "matchDatasources": [
        "docker"
      ],
      "groupName": "docker images",
      "addLabels": [
        "area: docker"
      ]
    },
    {
      "description": "Automerge low-risk patch updates after CI",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Require manual review for major updates",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    }
  ]
}
